generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model License {
  id         String    @id @default(uuid())
  userId     String?
  key        String    @unique
  plan       String    @default("pro")
  features   String?
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String?
  plan         String    @default("free")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  licenses     License[]
}

model Category {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subcategories Subcategory[]
  products      Product[]
}

model Subcategory {
  id         String    @id @default(uuid())
  categoryId String
  name       String
  slug       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([categoryId, slug])
}

model Product {
  id              String       @id @default(uuid())
  uniqueId        String       @unique
  website         String?
  supplier        String?
  brand           String?
  categoryId      String?
  subcategoryId   String?
  title           String?
  subtitle        String?
  description     String?
  htmlDescription String?
  shortDescription String?
  price           Float?
  salePrice       Float?
  currency        String?
  discount        Float?
  sku             String?
  barcode         String?
  stock           Int?
  availability    String?
  rating          Float?
  reviewCount     Int?
  tags            String?
  collections     String?
  variants        String?
  colors          String?
  sizes           String?
  weight          String?
  dimensions      String?
  material        String?
  country         String?
  shipping        String?
  videos          String?
  documents       String?
  faqs            String?
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  seoKeywords     String?
  breadcrumbs     String?
  createdDate     String?
  updatedDate     String?
  scrapedDate     DateTime     @default(now())
  productUrl      String?
  imageCount      Int          @default(0)
  specifications  String?
  attributes      String?
  customFields    String?
  platform        String?
  hash            String?
  folderPath      String?
  sessionId       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  category        Category?    @relation(fields: [categoryId], references: [id])
  subcategory     Subcategory? @relation(fields: [subcategoryId], references: [id])
  session         Session?     @relation(fields: [sessionId], references: [id])
  images          Image[]
  downloads       Download[]

  @@index([sku])
  @@index([productUrl])
  @@index([hash])
  @@index([sessionId])
}

model Image {
  id           String   @id @default(uuid())
  productId    String
  url          String
  filename     String?
  localPath    String?
  thumbnailPath String?
  alt          String?
  position     Int      @default(0)
  isCover      Boolean  @default(false)
  hash         String?
  width        Int?
  height       Int?
  size         Int?
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([hash])
}

model Session {
  id               String    @id @default(uuid())
  mode             String
  status           String    @default("idle")
  platform         String?
  websiteUrl       String
  productsFound    Int       @default(0)
  productsSaved    Int       @default(0)
  imagesDownloaded Int       @default(0)
  errors           Int       @default(0)
  currentUrl       String?
  productUrls      String?
  metadata         String?
  startedAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
  pausedAt         DateTime?
  products         Product[]
  logs             Log[]
  downloads        Download[]
}

model Log {
  id        String   @id @default(uuid())
  sessionId String?
  level     String
  message   String
  metadata  String?
  timestamp DateTime @default(now())
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([timestamp])
}

model Download {
  id        String   @id @default(uuid())
  sessionId String?
  productId String?
  url       String
  status    String   @default("pending")
  filename  String?
  localPath String?
  error     String?
  retries   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([status])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Selector {
  id        String   @id @default(uuid())
  name      String
  domain    String
  selectors String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
}

model Adapter {
  id        String   @id @default(uuid())
  name      String
  platform  String
  domains   String
  selectors String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
}
