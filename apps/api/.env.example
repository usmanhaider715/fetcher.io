NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# MongoDB (self-hosted on VPS or Atlas)
MONGODB_URI=mongodb://fetcher:changeme@127.0.0.1:27017/fetcherio?authSource=admin

# Redis
REDIS_URL=redis://:changeme@127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# AI providers (proxied — never expose to extension)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@fetcherio.dev

# CORS — comma-separated origins
CORS_ORIGINS=https://fetcherio.dev,https://www.fetcherio.dev,https://app.fetcherio.dev,https://admin.fetcherio.dev

# App URLs
WEB_URL=https://app.fetcherio.dev
MARKETING_URL=https://fetcherio.dev
