# Root environment reference — copy per-app examples:
#   apps/api/.env.example  → apps/api/.env
#   apps/web/.env.example  → apps/web/.env.local
#   apps/backend/.env.example → apps/backend/.env

NODE_ENV=production

# VPS deployment paths
DEPLOY_DIR=/var/www/fetcherio
DEPLOY_USER=deploy

# Domains
MARKETING_URL=https://productfetcher.online
APP_URL=https://app.productfetcher.online
API_URL=https://api.productfetcher.online
ADMIN_URL=https://admin.productfetcher.online
DOCS_URL=https://docs.productfetcher.online
